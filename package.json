{
  "name": "electron-react-express-mysql",
  "version": "1.0.0",
  "description": "Electron app with React frontend, Express backend, and MySQL",
  "main": "main.js",
  "author": "porakero",
  
  "scripts": {
    "start": "electron-forge start",
    "dev": "concurrently \"npm run server\" \"wait-on http://localhost:3001 && npm run watch\" \"wait-on http://localhost:3001 && npm start\"",
    "electron": "cross-env NODE_ENV=development electron .",
    "server": "node server/server.js",
    "build": "webpack --mode production",
    "watch": "webpack --mode development --watch",
    "package": "electron-forge package",
    "make": "electron-forge make"
  },
  "dependencies": {
    "axios": "^1.4.0",
    "electron-squirrel-startup": "^1.0.1",
    "express": "^4.18.2",
    "mysql2": "^3.6.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-icons": "^5.6.0"
  },
  "devDependencies": {
    "@babel/core": "^7.22.0",
    "@babel/preset-env": "^7.22.0",
    "@babel/preset-react": "^7.22.0",
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-deb": "^7.11.2",
    "@electron-forge/maker-rpm": "^7.11.2",
    "@electron-forge/maker-squirrel": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.2",
    "@electron-forge/plugin-fuses": "^7.11.2",
    "@electron/fuses": "^1.8.0",
    "babel-loader": "^9.1.0",
    "concurrently": "^8.2.0",
    "cross-env": "^10.1.0",
    "css-loader": "^7.1.4",
    "electron": "^25.9.8",
    "electron-reload": "^2.0.0-alpha.1",
    "html-webpack-plugin": "^5.5.0",
    "style-loader": "^4.0.0",
    "wait-on": "^7.0.1",
    "webpack": "^5.88.0",
    "webpack-cli": "^5.1.0"
  }
}
